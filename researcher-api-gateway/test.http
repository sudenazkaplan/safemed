@baseUrl = http://localhost:8080

### 1) register a new researcher
# @name register
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "username": "researcher1",
  "password": "secret123",
  "institution": "SafeMed University"
}

### 2) login to get the jwt token
# @name login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "username": "researcher1",
  "password": "secret123"
}

# grab token from the login response
@token = {{login.response.body.token}}

### 3) create a dataset request (needs bearer token)
# @name createRequest
POST {{baseUrl}}/api/v1/datasets/request
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "ageMin": 18,
  "ageMax": 65,
  "diseaseType": "Diabetes"
}

# id + token returned with the new request
@requestId = {{createRequest.response.body.id}}
@downloadToken = {{createRequest.response.body.downloadToken}}

### 4) list my requests (second call should hit redis cache)
GET {{baseUrl}}/api/v1/datasets/requests/my
Authorization: Bearer {{token}}

### 5) download before processing -> status is PENDING, returns "not ready"
GET {{baseUrl}}/api/v1/datasets/download/{{downloadToken}}
Authorization: Bearer {{token}}

### 6) register a callback webhook url (use a real https://webhook.site/... url to see it fire)
POST {{baseUrl}}/api/v1/researchers/webhooks
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "callbackUrl": "https://webhook.site/your-unique-id"
}

### 7) simulate data completion -> flips to PROCESSED and fires DatasetReadyNotificationSent webhook
POST {{baseUrl}}/api/v1/datasets/requests/{{requestId}}/complete
Authorization: Bearer {{token}}

### 8) download after processing -> now returns the anonymized records
GET {{baseUrl}}/api/v1/datasets/download/{{downloadToken}}
Authorization: Bearer {{token}}
